# Example split-production values.
# Set backend values in Render and frontend values in Vercel instead of committing real secrets.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/habit_steak?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
CLIENT_ORIGIN="https://habit-steak.vercel.app"
APP_TIMEZONE="Asia/Ho_Chi_Minh"
VITE_API_URL="https://your-backend.onrender.com/api"