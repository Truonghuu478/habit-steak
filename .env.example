# Copy this file to .env.development for local development.
# Production should use platform-provided environment variables instead of a committed env file.
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5433/habit_steak?schema=public"
JWT_SECRET="replace-with-a-long-random-secret"
PORT=4000
CLIENT_ORIGIN="http://localhost:5173"
APP_TIMEZONE="Asia/Ho_Chi_Minh"
# Optional in production when the same service serves both frontend and API.
VITE_API_URL="http://localhost:4000/api"
